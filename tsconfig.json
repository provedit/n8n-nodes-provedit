{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "preserveConstEnums": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "useUnknownInCatchVariables": false
  },
  "include": ["credentials/**/*", "nodes/**/*", "nodes/**/*.json"],
  "exclude": ["dist/**/*", "node_modules/**/*"]
}
